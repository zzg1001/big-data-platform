SELECT
    -- 酒店基础信息
    h.id AS hotel_id,
    h.hotel_no,
    h.name AS hotel_name,
    h.brand,
    h.tier,
    h.star_rating,
    h.city,
    h.province,
    h.address,
    h.latitude,
    h.longitude,
    h.has_breakfast,
    h.has_gym,
    h.has_parking,
    h.has_meeting_room,
    h.checkin_time,
    h.checkout_time,
    
    -- 价格信息
    hp.room_type,
    hp.base_price,
    hp.weekend_price,
    hp.holiday_price,
    hp.member_discount,
    hp.corporate_discount,
    ROUND(hp.base_price * hp.corporate_discount) AS corp_price,
    
    -- 评分口碑
    hr.overall_score,
    hr.cleanliness_score,
    hr.service_score,
    hr.location_score,
    hr.value_score,
    hr.facility_score,
    hr.would_recommend,
    hr.comment,
    
    -- 位置距离（到工厂）
    sf.id AS factory_id,
    sf.name AS factory_name,
    sf.city AS factory_city,
    hfd.straight_distance_km,
    hfd.drive_distance_km,
    hfd.drive_time_min,
    hfd.taxi_cost_estimate,
    hfd.subway_available,
    hfd.subway_time_min,
    
    -- 员工信息
    e.id AS emp_id,
    e.emp_no,
    e.name AS emp_name,
    e.department,
    e.position,
    e.level AS emp_level,
    e.budget_tier,
    e.monthly_budget,
    e.prefer_hotel_brand,
    e.prefer_room_type,
    
    -- 员工偏好
    ep.preferred_tier,
    ep.max_distance_km,
    ep.preferred_price_range_low,
    ep.preferred_price_range_high,
    ep.must_have_breakfast,
    ep.must_have_parking,
    ep.preferred_booking_channel,
    ep.preferred_checkin_time,
    
    -- 历史入住记录
    ti.checkin_date,
    ti.checkout_date,
    ti.nights,
    ti.unit_price,
    ti.total_amount,
    ti.booking_channel,
    ti.is_preferred
FROM hotel h
LEFT JOIN hotel_price hp ON h.id = hp.hotel_id
LEFT JOIN hotel_review hr ON h.id = hr.hotel_id
LEFT JOIN hotel_factory_distance hfd ON h.id = hfd.hotel_id
LEFT JOIN supplier_factory sf ON hfd.factory_id = sf.id
LEFT JOIN travel_itinerary ti ON h.id = ti.hotel_id
LEFT JOIN travel_request tr ON ti.request_id = tr.id
LEFT JOIN employee e ON tr.emp_id = e.id
LEFT JOIN employee_preference ep ON e.id = ep.emp_id

